# Copy this file to `.env` and fill in the values. NEVER commit `.env`.

# The shared team database (Neon Postgres). Get the string from the team chat.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# EIA (Brent/WTI daily) — free key by email: https://www.eia.gov/opendata/
EIA_API_KEY=

# AISStream (live ship positions) — free key via GitHub login: https://aisstream.io/
AISSTREAM_API_KEY=

# How many seconds the AIS loader listens before saving a snapshot
AIS_SECONDS=60

# AISStream free tier only covers Europe/US. Box = [[[latMin,lonMin],[latMax,lonMax]]]
# Default in code is the English Channel / North Sea (proven coverage).
#AIS_BBOX=[[[48.0,-6.0],[58.0,12.0]]]

# GDELT pipeline ------------------------------------------------------------
# public   = free daily dumps, no account needed (default)
# bigquery = richer data (mentions + GKG themes), needs Google Cloud creds
GDELT_SOURCE=public
GDELT_WINDOW_DAYS=30
#GCP_PROJECT=project-21508f3b-5710-4110-999

# OpenRouter key — only needed for the LLM extractors
# (extract_events.py / hybrid_extract.py); the deterministic default needs none.
OPENROUTER_API_KEY=

# Controller: prune AIS positions older than this many hours
VESSEL_RETENTION_HOURS=48

# Agent layer (agents/) --------------------------------------------------------
# LLM used for agent NARRATION only — every number is computed deterministically,
# so the pipeline still runs end-to-end with no key (falls back to templates).
# Default provider is Cerebras: free tier + fastest inference (the 47s pitch).
LLM_PROVIDER=cerebras
CEREBRAS_API_KEY=
# Optional: override the model / pick another provider (see agents/config.py)
#LLM_MODEL=gpt-oss-120b
#GROQ_API_KEY=
# LLM_PROVIDER=openrouter  (reuses OPENROUTER_API_KEY above)

# Fire the scenario+procurement chain when a corridor's disruption prob >= this
DISRUPTION_THRESHOLD=0.5
# Per-LLM-call timeout (s); a throttled call falls back to its template
LLM_TIMEOUT_S=10
